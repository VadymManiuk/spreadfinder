# =============================================================================
# Spread Scanner Bot — Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Filter Thresholds ---
# MIN_GROSS_SPREAD_BPS=10.0
# MIN_NET_SPREAD_BPS=5.0
# MIN_BID_SIZE=100.0
# MIN_ASK_SIZE=100.0
# MIN_VOLUME_24H=               # empty = disabled
# MAX_DATA_AGE_MS=2000
# COOLDOWN_SECONDS=300
# PERSISTENCE_MS=1000
# MIN_CONFIDENCE=0.3

# --- Exchange Fees (decimal fractions) ---
# BINANCE_MAKER=0.0002
# BINANCE_TAKER=0.0004
# HYPERLIQUID_MAKER=0.0002
# HYPERLIQUID_TAKER=0.0005
# GATE_MAKER=0.00015
# GATE_TAKER=0.0005
# SLIPPAGE_FACTOR=0.0001

# --- Adapter Settings ---
# STALE_THRESHOLD_SECONDS=10.0
# HEARTBEAT_INTERVAL_SECONDS=30.0
# META_POLL_INTERVAL_SECONDS=30.0

# --- General ---
# LOG_LEVEL=INFO
# ENABLED_EXCHANGES=binance,hyperliquid,gate
